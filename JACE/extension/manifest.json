{
  "manifest_version": 3,
  "name": "JACE - Critical Thinking AI Helper",
  "version": "5.0.0",
  "description": "Encourages critical thinking before sending prompts to AI chatbots through personalized reflection questions",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://chatgpt.com/*",
    "*://chat.openai.com/*",
    "*://claude.ai/*",
    "*://gemini.google.com/*",
    "*://copilot.microsoft.com/*",
    "https://cti-proxy.hall-justinanthony.workers.dev/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*",
    "https://gzqyuhkikeyaieqijgps.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://chat.openai.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*",
        "*://copilot.microsoft.com/*"
      ],
      "js": ["supabase-client.js", "content-script.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/i16.png",
      "48": "icons/i48.png",
      "128": "icons/i128.png"
    }
  },
  "icons": {
    "16": "icons/i16.png",
    "48": "icons/i48.png",
    "128": "icons/i128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
